DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=

SUMMARIZER_URL=http://127.0.0.1:8001
SUMMARIZER_TIMEOUT=30.0

# 아래 두 형식 중 하나 (JSON 배열은 반드시 json.loads 가능한 문자열일 것)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://[::1]:5173
# CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://[::1]:5173"]


# 목록 전체 로드 기본(GET /api/news LIMIT 없음). 상한 필요 시만 ?limit= (최대 200000)
STATS_CORPUS_DAYS=90
STATS_RECENT_N=4
STATS_TOP_N=8
STATS_USE_LLM=false
# 연관어 품질용 (설치 필요: keybert, sentence-transformers); 실패하면 자동으로 규칙 기반만 사용
STATS_USE_KEYBERT=true
# 기본 false: 표시 날짜 = DB news_articles.date (pgAdmin 과 동일).
# true 일 때만 보조: news_id 내 YYYYMMDD → 본문 한글 날짜 순 (본문만 쓰면 모든 기사가 같은 날로 보일 수 있음).
DISPLAY_DATE_FALLBACK=false
