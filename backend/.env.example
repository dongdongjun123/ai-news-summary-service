# Neon: Dashboard → Connect → Connection string
DATABASE_URL=
# Local (DATABASE_URL 비우면 사용)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=
DB_SSLMODE=
DB_CONNECT_TIMEOUT=15

SUMMARIZER_URL=http://127.0.0.1:8001
SUMMARIZER_TIMEOUT=30.0

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://[::1]:5173

STATS_CORPUS_DAYS=90
STATS_RECENT_N=4
STATS_TOP_N=8
STATS_USE_LLM=false
STATS_USE_KEYBERT=true
DISPLAY_DATE_FALLBACK=false

# false: summarizer·stat_summary 미호출 (프론트–백엔드–DB 연결만 테스트할 때)
ENABLE_AI=false
